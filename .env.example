# .env.example — copie para .env e preencha. NUNCA commite o .env real.

# PostgreSQL
POSTGRES_USER=sbrchecks
POSTGRES_PASSWORD=troque_esta_senha_forte
POSTGRES_DB=sbrchecks

# MinIO (storage de fotos)
MINIO_ROOT_USER=sbrchecks
MINIO_ROOT_PASSWORD=troque_esta_senha_forte
S3_BUCKET=visitas-fotos

# API
JWT_SECRET=gere_um_segredo_longo_e_aleatorio
JWT_REFRESH_SECRET=gere_outro_segredo_longo_e_aleatorio
PORT=3000

# Google OAuth (obter no Google Cloud Console)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
ALLOWED_DOMAIN=laboratoriosobral.com.br

# Admin seed (email do owner/superadmin)
SEED_ADMIN_EMAIL=paulinete.miranda@laboratoriosobral.com.br

# Frontend (mesmo Client ID — prefixo VITE_ obrigatório para o Vite expor)
VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
